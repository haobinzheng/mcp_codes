#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=start_ai_tool_logging.sh
source "${SCRIPT_DIR}/start_ai_tool_logging.sh"

PYTHON="${PYTHON:-python3}"

cd "${SCRIPT_DIR}"

ADK_WEB_HOST="${ADK_WEB_HOST:-127.0.0.1}"
# Default avoids collisions with Flask (8000), other ADK web instances, and common dev servers.
ADK_WEB_PORT="${ADK_WEB_PORT:-8787}"
AGENTS_DIR="${AGENTS_DIR:-${SCRIPT_DIR}/adk_agents}"

START_AI_TOOL_LOG_DIR="${START_AI_TOOL_LOG_DIR:-${SCRIPT_DIR}/logs}"
ADK_LOG_FILE="${ADK_LOG_FILE:-${START_AI_TOOL_LOG_DIR}/adk_web.log}"

# Project-local ADK state so sessions never mix with other agents or repos on the same machine.
ADK_DATA_DIR="${ADK_DATA_DIR:-${SCRIPT_DIR}/.adk_data}"
mkdir -p "${ADK_DATA_DIR}"

# Session backend: SQLite file when Python has sqlite3; else ADK in-memory (no _sqlite3).
SESSION_DB="${ADK_SESSION_SQLITE:-${ADK_DATA_DIR}/gfiber_web_sessions.sqlite}"
if [[ -n "${ADK_SESSION_SERVICE_URI:-}" ]]; then
  SESSION_URI="${ADK_SESSION_SERVICE_URI}"
elif "${PYTHON}" -c "import sqlite3" 2>/dev/null; then
  # SQLAlchemy / ADK: absolute SQLite path uses sqlite:////absolute/path (four slashes).
  SESSION_URI="sqlite:////${SESSION_DB}"
else
  SESSION_URI="memory://"
  echo "Warning: This Python has no sqlite3 module (_sqlite3). Using session_service_uri=memory:// (sessions vanish on restart)." >&2
  echo "Fix: install SQLite dev libs and rebuild Python (e.g. pyenv after libsqlite3-dev), or set ADK_SESSION_SERVICE_URI." >&2
fi

# reload=true watches the filesystem and can interact badly with multiple ADK projects; opt in only when needed.
ADK_WEB_RELOAD="${ADK_WEB_RELOAD:-false}"
RELOAD_ARGS=(--no-reload)
if [[ "${ADK_WEB_RELOAD}" == "true" ]] || [[ "${ADK_WEB_RELOAD}" == "1" ]]; then
  RELOAD_ARGS=(--reload)
fi

LOGO_TEXT="${ADK_LOGO_TEXT:-GFiber MCP (mcp_codes)}"

if start_ai_tool_logging_enabled; then
  start_ai_tool_log_begin "${ADK_LOG_FILE}" "start_ai_tool_adk" \
    "PYTHON=${PYTHON}" \
    "ADK_WEB_HOST=${ADK_WEB_HOST}" \
    "ADK_WEB_PORT=${ADK_WEB_PORT}" \
    "AGENTS_DIR=${AGENTS_DIR}" \
    "SESSION_DB=${SESSION_DB}" \
    "SESSION_URI=${SESSION_URI}" \
    "ADK_LOG_FILE=${ADK_LOG_FILE}"
  start_ai_tool_log_tee "${ADK_LOG_FILE}"
fi

echo "Starting ADK Web UI — agents from ${AGENTS_DIR}"
echo "Listening on ${ADK_WEB_HOST}:${ADK_WEB_PORT} (set ADK_WEB_PORT to avoid clashes)"
if [[ "${SESSION_URI}" == memory://* ]]; then
  echo "Session storage: in-memory (${SESSION_URI}; isolated per process, not persisted)"
else
  echo "Session DB: ${SESSION_DB} (isolated from other ADK apps)"
fi
echo "SSH tunnel from laptop: use REMOTE_PORT=${ADK_WEB_PORT} with start_ai_tool_adk_tunnel"
if start_ai_tool_logging_enabled; then
  echo "Logging to: ${ADK_LOG_FILE} (disable: START_AI_TOOL_LOG_DISABLE=1)"
fi
echo "Ensure GEMINI_API_KEY is set (see DESIGN_PIP_INSTALL.md)."
echo "Same agent as client_inmemory_v2_google_adk.py: open app gfiber_network in the ADK Web UI."
echo "Interactive CLI (stdio): ${PYTHON} client_inmemory_v2_adk.py"

# Gemini API key only; do not let google.genai / ADK prefer GOOGLE_API_KEY from the parent shell.
unset GOOGLE_API_KEY || true

exec "${PYTHON}" -m google.adk.cli web \
  --host "${ADK_WEB_HOST}" \
  --port "${ADK_WEB_PORT}" \
  "${RELOAD_ARGS[@]}" \
  --session_service_uri "${SESSION_URI}" \
  --logo-text "${LOGO_TEXT}" \
  "${AGENTS_DIR}"
