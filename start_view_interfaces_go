#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export WEB_HOST="${WEB_HOST:-127.0.0.1}"
export WEB_PORT="${WEB_PORT:-9000}"

cd "${SCRIPT_DIR}"

# Recompile the binary dynamically if 'go' is installed to ensure native compatibility on the host machine
if command -v go >/dev/null 2>&1; then
  echo "Compiling native dashboard server binary..."
  go build -o dashboard_server main.go
elif [ ! -f "dashboard_server" ]; then
  echo "Error: 'go' command not found, and no pre-compiled 'dashboard_server' binary exists."
  echo "Please install Go or compile main.go manually."
  exit 1
fi

echo "Starting GFiber Interface Audit Dashboard (Go) on ${WEB_HOST}:${WEB_PORT}"
echo "If running remotely, open an SSH tunnel from your Mac and browse to:"
echo "http://127.0.0.1:${WEB_PORT}"

exec ./dashboard_server
