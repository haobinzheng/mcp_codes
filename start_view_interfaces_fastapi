#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export WEB_HOST="${WEB_HOST:-127.0.0.1}"
export WEB_PORT="${WEB_PORT:-8792}"

cd "${SCRIPT_DIR}"

echo "Starting GFiber Interface Audit Dashboard (FastAPI) on ${WEB_HOST}:${WEB_PORT}"
echo "If running remotely, open an SSH tunnel from your Mac and browse to:"
echo "http://127.0.0.1:${WEB_PORT}"

exec python3 view_interfaces_fastapi.py
