#!/usr/bin/env bash

set -euo pipefail

# Same as start_ai_tool_web_tunnel: ssh -N -L so your laptop browser can reach a service on the remote.
# Use when the server has no web browser. Edit these placeholders for your environment.
SSH_USER="${SSH_USER:-mikezh}"
SSH_HOST="${SSH_HOST:-mikezh.c.googlers.com}"

if [[ $# -ge 1 ]]; then
  REMOTE_TARGET="$1"
else
  REMOTE_TARGET="${REMOTE_SSH_TARGET:-${SSH_USER}@${SSH_HOST}}"
fi

if [[ "${REMOTE_TARGET}" == "your-ssh-user@your-remote-host" ]]; then
  echo "Edit SSH_USER and SSH_HOST in this script before running it."
  exit 1
fi

# Defaults match start_ai_tool_adk (ADK_WEB_PORT=8787). Override if you changed ADK_WEB_PORT.
LOCAL_PORT="${LOCAL_PORT:-8787}"
REMOTE_HOST="${REMOTE_HOST:-127.0.0.1}"
REMOTE_PORT="${REMOTE_PORT:-8787}"

echo "Opening SSH tunnel to ${REMOTE_TARGET}"
echo "Keep this terminal open. Open this URL in your laptop browser (remote host may have no browser):"
echo "http://127.0.0.1:${LOCAL_PORT}"

exec ssh -N -L "${LOCAL_PORT}:${REMOTE_HOST}:${REMOTE_PORT}" "${REMOTE_TARGET}"
