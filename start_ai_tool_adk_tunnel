#!/usr/bin/env bash
# SSH local port forward: use your Mac browser while ADK Web runs on Linux (no GUI needed there).
# Remote target defaults match start_ai_tool_web_tunnel (edit SSH_USER / SSH_HOST or pass user@host).
# Default ports match start_ai_tool_adk (8787).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=start_ai_tool_logging.sh
source "${SCRIPT_DIR}/start_ai_tool_logging.sh"

# Same pattern and defaults as start_ai_tool_web_tunnel (override with SSH_USER, SSH_HOST, REMOTE_SSH_TARGET, or $1).
SSH_USER="${SSH_USER:-mikezh}"
SSH_HOST="${SSH_HOST:-mikezh.c.googlers.com}"

if [[ $# -ge 1 ]]; then
  REMOTE_TARGET="$1"
else
  REMOTE_TARGET="${REMOTE_SSH_TARGET:-${SSH_USER}@${SSH_HOST}}"
fi

if [[ "${REMOTE_TARGET}" == "your-ssh-user@your-remote-host" ]]; then
  echo "Edit SSH_USER and SSH_HOST in start_ai_tool_adk_tunnel (same defaults as start_ai_tool_web_tunnel)." >&2
  exit 1
fi

# On the remote, ADK Web should listen where this forward points (default loopback + ADK_WEB_PORT).
LOCAL_PORT="${LOCAL_PORT:-8787}"
REMOTE_HOST="${REMOTE_HOST:-127.0.0.1}"
REMOTE_PORT="${REMOTE_PORT:-8787}"

START_AI_TOOL_LOG_DIR="${START_AI_TOOL_LOG_DIR:-${SCRIPT_DIR}/logs}"
ADK_TUNNEL_LOG_FILE="${ADK_TUNNEL_LOG_FILE:-${START_AI_TOOL_LOG_DIR}/adk_tunnel.log}"

if start_ai_tool_logging_enabled; then
  start_ai_tool_log_begin "${ADK_TUNNEL_LOG_FILE}" "start_ai_tool_adk_tunnel" \
    "REMOTE_TARGET=${REMOTE_TARGET}" \
    "LOCAL_PORT=${LOCAL_PORT}" \
    "REMOTE_HOST=${REMOTE_HOST}" \
    "REMOTE_PORT=${REMOTE_PORT}" \
    "ADK_TUNNEL_LOG_FILE=${ADK_TUNNEL_LOG_FILE}"
  start_ai_tool_log_tee "${ADK_TUNNEL_LOG_FILE}"
fi

echo "SSH tunnel: Mac 127.0.0.1:${LOCAL_PORT} → ${REMOTE_TARGET} ${REMOTE_HOST}:${REMOTE_PORT}"
echo "On the Linux host, ADK Web should already be running (./start_ai_tool_adk with GEMINI_API_KEY set)."
echo "Keep this terminal open. On your Mac, open:"
echo "  http://127.0.0.1:${LOCAL_PORT}"
if start_ai_tool_logging_enabled; then
  echo "Logging to: ${ADK_TUNNEL_LOG_FILE} (disable: START_AI_TOOL_LOG_DISABLE=1)"
fi

if [[ "$(uname -s)" == "Darwin" && "${START_AI_TOOL_TUNNEL_OPEN_BROWSER:-0}" == "1" ]]; then
  open "http://127.0.0.1:${LOCAL_PORT}" || true
fi

exec ssh -N -L "${LOCAL_PORT}:${REMOTE_HOST}:${REMOTE_PORT}" "${REMOTE_TARGET}"
