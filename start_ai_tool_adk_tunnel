#!/usr/bin/env bash

set -euo pipefail

# Edit these placeholders for your environment.
# Port-forward mode below matches start_ai_tool_web_tunnel (same LOCAL_PORT, REMOTE_HOST, REMOTE_PORT).
# For an interactive TTY on the remote running ./start_ai_tool_adk, set ADK_TUNNEL_MODE=interactive.
SSH_USER="${SSH_USER:-mikezh}"
SSH_HOST="${SSH_HOST:-mikezh.c.googlers.com}"

if [[ $# -ge 1 ]]; then
  REMOTE_TARGET="$1"
else
  REMOTE_TARGET="${REMOTE_SSH_TARGET:-${SSH_USER}@${SSH_HOST}}"
fi

if [[ "${REMOTE_TARGET}" == "your-ssh-user@your-remote-host" ]]; then
  echo "Edit SSH_USER and SSH_HOST in this script before running it."
  exit 1
fi

ADK_TUNNEL_MODE="${ADK_TUNNEL_MODE:-interactive}"

if [[ "${ADK_TUNNEL_MODE}" == "interactive" ]]; then
  # Remote shell: runs ADK client there (MCP server is started over stdio by the client).
  REMOTE_REL="${REMOTE_REL:-mcp_codes}"

  echo "Interactive mode (ADK_TUNNEL_MODE=interactive)"
  echo "Remote session -> ${REMOTE_TARGET}"
  if [[ -n "${REMOTE_ABS:-}" ]]; then
    echo "Remote cwd: ${REMOTE_ABS} (REMOTE_ABS)"
  else
    echo "Remote cwd: \$HOME/${REMOTE_REL} on the server (override REMOTE_REL or set REMOTE_ABS)"
  fi
  echo "The ADK client starts server_inmemory_v2.py over stdio automatically."
  echo
  echo "For an SSH port forward like start_ai_tool_web_tunnel, run with:"
  echo "  ADK_TUNNEL_MODE=port-forward ${0##*/} ${REMOTE_TARGET}"
  echo

  if [[ -n "${REMOTE_ABS:-}" ]]; then
    _remote_cd=$(printf '%q' "${REMOTE_ABS}")
    exec ssh -t "${REMOTE_TARGET}" "bash --login -c 'cd ${_remote_cd} && exec ./start_ai_tool_adk'"
  else
    exec ssh -t "${REMOTE_TARGET}" "bash --login -c 'cd \"\$HOME/${REMOTE_REL}\" && exec ./start_ai_tool_adk'"
  fi
fi

# --- Same tunnel as start_ai_tool_web_tunnel ---
LOCAL_PORT="${LOCAL_PORT:-8000}"
REMOTE_HOST="${REMOTE_HOST:-127.0.0.1}"
REMOTE_PORT="${REMOTE_PORT:-8000}"

echo "Opening SSH tunnel to ${REMOTE_TARGET}"
echo "Keep this terminal open while using the web client."
echo "Open this URL in your Mac browser:"
echo "http://127.0.0.1:${LOCAL_PORT}"

exec ssh -N -L "${LOCAL_PORT}:${REMOTE_HOST}:${REMOTE_PORT}" "${REMOTE_TARGET}"
