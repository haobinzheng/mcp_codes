#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WEB_HOST="${WEB_HOST:-127.0.0.1}"
WEB_PORT="${WEB_PORT:-8000}"

cd "${SCRIPT_DIR}"

echo "Starting GFiber v2 web client on ${WEB_HOST}:${WEB_PORT}"
echo "After you open the SSH tunnel from your Mac, browse to:"
echo "http://127.0.0.1:${WEB_PORT}"

exec python3 client_inmemory_v2_web.py
